<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent directory listing
    Options -Indexes

    # --- URL Routing: map clean public URLs to actual file locations ---
    # legal/* → public/legal/*
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^legal/(.*)$ public/legal/$1 [L]

    # Protect sensitive directories (must come AFTER routing rules)
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^core/ - [F,L]
    RewriteRule ^database/ - [F,L]

    # Block access to error logs and database dumps
    <FilesMatch "\.(log|sql|bak|ini|env|sh)$">
        Require all denied
    </FilesMatch>

    # Handle URL rewriting to enforce HTTPS if desired (uncomment below if SSL is active)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Allow CSS, JS, Images to be accessed normally 
    # (By default Apache handles this, but ensures no rewrite conflicts)
</IfModule>

# Caching for Production performance
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>
